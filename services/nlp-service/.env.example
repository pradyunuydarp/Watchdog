APP_NAME=watchdog-nlp-service
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
DEFAULT_CATEGORY=unknown
DEFAULT_SEVERITY=low
ANALYZER_BACKEND=heuristic
MODEL_ARCHITECTURE=gru
MODEL_DEVICE=cpu
MODEL_ARTIFACT_PATH=artifacts/model-bundle.pt
TRAINING_DATA_PATH=data/training/incidents.jsonl
TRAINING_RANDOM_SEED=42
SEQUENCE_EPOCHS=12
SEQUENCE_BATCH_SIZE=8
SEQUENCE_MAX_VOCAB_SIZE=5000
SEQUENCE_MAX_SEQUENCE_LENGTH=64
PLANNED_MODEL_ENCODER_NAME=set-me-later
PLANNED_MODEL_TOKENIZER_NAME=set-me-later
ATTENTION_NUM_HEADS=8
TRANSFORMER_MODEL_NAME=set-me-later
