COMPOSE_PROJECT_NAME=watchdog

KAFKA_PORT=9092
KAFKA_BROKERS=kafka:9092

CORE_SERVICE_PORT=8080
WATCHER_SERVICE_PORT=8081
NLP_SERVICE_PORT=8082
DASHBOARD_PORT=4173
NLP_ANALYZER_BACKEND=heuristic
NLP_MODEL_ARCHITECTURE=gru
NLP_MODEL_ARTIFACT_PATH=artifacts/model-bundle.pt
NLP_MODEL_DEVICE=cpu
NLP_TRAINING_DATA_PATH=data/training/incidents.jsonl
NLP_PLANNED_MODEL_ENCODER_NAME=set-me-later
NLP_PLANNED_MODEL_TOKENIZER_NAME=set-me-later
NLP_ATTENTION_NUM_HEADS=8
NLP_TRANSFORMER_MODEL_NAME=set-me-later

# Supabase local (dockerized) defaults.
# Supabase typically exposes:
# - Postgres on 54322
# - Auth API on 54321
SUPABASE_DB_HOST=host.docker.internal
SUPABASE_DB_PORT=54322
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=postgres

SUPABASE_AUTH_ISSUER=http://host.docker.internal:54321/auth/v1
# Dev-only secret; replace with the local Supabase JWT secret if validating HS256 locally.
SUPABASE_JWT_SECRET=dev-only-change-me
SUPABASE_AUTH_JWK_SET_URI=
SUPABASE_AUTH_EXPECTED_AUDIENCE=authenticated

WATCHER_PUBLISH_MODE=kafka
NLP_API_PORT=8000

WATCHDOG_KAFKA_ENABLED=true
WATCHDOG_KAFKA_GROUP_ID=watchdog-core-service
WATCHDOG_KAFKA_POINTER_TOPIC=watchdog.pointer-events.v1
WATCHDOG_KAFKA_ENRICHMENT_TOPIC=watchdog.enrichment-events.v1
WATCHDOG_KAFKA_DLQ_TOPIC=watchdog.dlq.v1

VITE_DASHBOARD_API_MODE=mock
VITE_DASHBOARD_API_BASE_URL=http://localhost:8080
VITE_DASHBOARD_REFRESH_MS=15000
